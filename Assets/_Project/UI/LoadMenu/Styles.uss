.menu {
    height: 100%;
    width: 100%;
    padding: 50px;
    align-items: center;
}

.menu__title {
    font-size: 12px;
    margin-bottom: 0;
}

.menu__subtitle {
    font-size: 8px;
    margin-top: 0;
}

.menu__option-container {
    border-width: 0;
    margin-top: 6px;
    padding: 0;
    width: 30%;
}

.menu__option {
    height: 10%;
    font-size: 8px;
    border-radius: 2px;
    border-width: 0;
}
