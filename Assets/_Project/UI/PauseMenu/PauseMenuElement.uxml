<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <ui:VisualElement name="MenuContainer" style="flex-grow: 1; justify-content: center; align-items: center; align-self: center;">
        <ui:GroupBox name="PauseMenu" style="height: 250px; width: 500px; background-color: rgba(255, 255, 255, 0.502); justify-content: center; align-items: center; align-self: center; align-content: auto; -unity-text-align: upper-left; flex-direction: row;">
            <ui:Button text="Quit" name="QuitButton" style="width: 200px; height: 50px; font-size: 20px; -unity-font-style: bold-and-italic;"/>
            <ui:Button text="Resume" name="ResumeButton" style="width: 200px; height: 50px; font-size: 20px; -unity-font-style: bold-and-italic; justify-content: flex-start;"/>
        </ui:GroupBox>
    </ui:VisualElement>
</ui:UXML>
